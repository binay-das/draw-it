generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  rooms  Room[]  @relation("RoomAdmin")
  shapes Shape[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id       String  @id @default(cuid())
  slug     String
  isShared Boolean @default(false)

  adminId String
  admin   User   @relation("RoomAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  shapes Shape[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adminId, slug])
  @@index([adminId])
}

enum ShapeType {
  rectangle
  square
  circle
  line
  arrow
  text
  pencil
}

model Shape {
  id     String    @id @default(cuid())
  type   ShapeType
  x      Float
  y      Float
  width  Float
  height Float
  text   String?
  points String?

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([userId])
}
